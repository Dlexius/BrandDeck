  "approved_color_tokens": {
    "primary_orange": "#FF5200",
    "secondary_orange": "#F97D40",
    "template_coral": "#E46962",
    "charcoal": "#1D1B1A",
    "ink": "#3A3735",
    "medium_gray": "#787E89",
