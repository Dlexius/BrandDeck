      "max_text_lengths": {
        "title": 48,
        "agenda_items": 68
      },
      "approved_chart_types": []
    },
    {
      "layout_id": "statement",
      "name": "Statement",
      "purpose": "Bold framing statement that sets the meeting goal or key message, with an approved emphasis phrase.",
      "required_placeholders": ["statement_text"],
      "max_text_lengths": {
        "title": 40,
        "statement_text": 180,
        "statement_emphasis": 60
