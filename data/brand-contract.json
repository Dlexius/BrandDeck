  "logo_rules": {
    "lockup_text": "Procore Demo Brand",
    "placement": "Bottom-left Procore wordmark with top-right hexagon mark, matching the approved template layout.",
    "clear_space": "At least 0.2 in around the lockup.",
    "minimum_size": "1.15 in wide",
    "background_rule": "Use charcoal text on light backgrounds and white text on dark backgrounds.",
    "do_not": [
      "Do not stretch, rotate, recolor, or place the lockup over busy imagery.",
      "Do not replace the wordmark with an unapproved logo."
    ]
  },
  "chart_color_rules": {
    "palette": ["#FF5200", "#3A3735", "#787E89", "#F97D40", "#D7CABF"],
    "neutral_gridline": "#D7CABF",
    "axis_label": "#3A3735",
    "use_orange_for": "primary measure or current period",
    "forbidden_chart_colors": ["#00FF00", "#0000FF", "#800080", "#FF00FF"]
  },
  "forbidden_rules": [
    "Do not invent new slide layouts outside the approved layout list.",
    "Do not use unapproved colors, gradients, shadows, or decorative effects in generated slides.",
    "Do not resize logos inconsistently between slides.",
    "Do not place more text than the layout maximums allow.",
    "Do not allow AI-generated prose to select fonts, colors, charts, or object positions.",
    "Do not use chart types outside the approved chart list for each layout.",
    "Do not expose model names, API providers, or generation internals in client-facing decks."
  ],
  "approved_layouts": [
    {
      "layout_id": "title_client_report",
      "name": "Title Client Report",
      "purpose": "Opening title slide for a client-facing adoption report.",
      "required_placeholders": ["client_name", "report_period", "subtitle"],
      "max_text_lengths": {
        "title": 64,
        "client_name": 48,
        "report_period": 36,
        "subtitle": 120
      },
      "approved_chart_types": []
    },
    {
      "layout_id": "agenda",
      "name": "Agenda",
